<?xml version="1.0" encoding="UTF-8"?>
<gdml xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="http://service-spi.web.cern.ch/service-spi/app/releases/GDML/schema/gdml.xsd">
  <materials>
    <material name="Vacuum" state="gas" Z="1">
      <D value="1e-25" unit="g/cm3"/>
      <atom value="1.00794" unit="g/mole"/>
    </material>
    <material name="LiquidArgon" state="liquid" Z="18">
      <D value="1.396" unit="g/cm3"/>
      <atom value="39.948" unit="g/mole"/>
    </material>
  </materials>
  <solids>
    <box name="WorldBox" x="700" y="700" z="700" lunit="cm"/>
    <box name="LArVatBox" x="600" y="600" z="600" lunit="cm"/>
  </solids>
  <structure>
    <volume name="LArVat">
      <materialref ref="LiquidArgon"/>
      <solidref ref="LArVatBox"/>
      <auxiliary auxtype="SensDet" auxvalue="LArTPC"/>
      <auxiliary auxtype="StepLimit" auxvalue="1.0 mm"/>
      <!-- Nominal LArTPC drift field; Doke-Birks uses its magnitude. -->
      <auxiliary auxtype="EField" auxvalue="(500 V/cm, 0 V/cm, 0 V/cm)"/>
    </volume>
    <volume name="World">
      <materialref ref="Vacuum"/>
      <solidref ref="WorldBox"/>
      <!-- Keep the nominal field across the outer vacuum shell so edep-sim
           sees it when an LAr step ends exactly on the volume boundary. -->
      <auxiliary auxtype="EField" auxvalue="(500 V/cm, 0 V/cm, 0 V/cm)"/>
      <physvol>
        <volumeref ref="LArVat"/>
        <position name="LArVatPosition" x="0" y="0" z="0" unit="cm"/>
      </physvol>
    </volume>
  </structure>
  <setup name="Default" version="1.0">
    <world ref="World"/>
  </setup>
</gdml>
